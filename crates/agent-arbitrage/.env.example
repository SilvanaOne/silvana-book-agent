# Copy to .env and fill in values.
# Never commit .env — it is gitignored.

# ────────────────────────────────────────────────────────────────────────
# Server config
# ────────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL via infra/docker-compose.yml)
# ────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/arbitrage_agent?schema=public

# ────────────────────────────────────────────────────────────────────────
# Redis (queue + cache via infra/docker-compose.yml)
# ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ────────────────────────────────────────────────────────────────────────
# Silvana host runtime
# (see md_docs/14-silvana-host-runtime.md)
# ────────────────────────────────────────────────────────────────────────
# Mode:
#   standalone-dev — no Silvana onboarding needed (Sprint 0/1 CEX-only)
#   production     — full cloud-agent sidecar required (Sprint 3+)
SILVANA_HOST_MODE=standalone-dev

# Production mode fields (filled by infra/silvana-agent/onboard.sh):
# PARTY_AGENT=
# PARTY_AGENT_PRIVATE_KEY=
# PARTY_AGENT_PUBLIC_KEY=
# ORDERBOOK_GRPC_URL=https://orderbook-devnet.silvana.dev:443
# CANTON_CHAIN=devnet
# SYNCHRONIZER_ID=
# DSO=

# ────────────────────────────────────────────────────────────────────────
# Proprietary engines — external isolated clusters
# (per md_docs/12-component-split-open-vs-proprietary.md)
#
# Open core HTTP clients call these endpoints. Executor runs from sibling repo
# silvana-executor/ (separate git); start it there and point EXECUTOR_API_URL here.
# Rebalancer skeleton is gitignored and not in active use.
#
# Managed mode (Silvana-hosted): omit EXECUTOR_API_URL. Set SIGNER_* below;
# on startup the scanner POSTs /agent/heartbeat to Vault and receives
# https://exec-{id}.silvana.dev + per-tenant token. See md_docs/16-managed-executor-runtime.md.
# ────────────────────────────────────────────────────────────────────────
EXECUTOR_API_URL=http://localhost:4001
EXECUTOR_API_TOKEN=

REBALANCER_API_URL=http://localhost:4002
REBALANCER_API_TOKEN=

# Signing vault (arbitrage-signer) — single source of CEX API keys + EVM/seed
# wallet keys. Model (B): engines fetch a scoped runtime bundle and sign locally.
# Canton Ed25519 identity is NOT here (cloud-agent / Silvana host). See md_docs/upgrade-plan.md.
SIGNER_API_URL=http://localhost:4003
SIGNER_API_TOKEN=
# Tenant UUID from Silvana Vault UI (Agent User ID)
SIGNER_TENANT_USER_ID=

# In Sprint 0/1 these may be unavailable — scanner runs in detection-only mode.
# The *_API_TOKEN values are the per-engine HMAC secrets used to sign requests.

# U4 forwarding tunables — when STRATEGY_MODE != paper, the scanner forwards
# accepted opportunities to the executor and polls; inventory is pulled from the
# rebalancer every SKEW_POLL_CYCLES scan cycles.
EXECUTOR_MAX_SLIPPAGE_BPS=20
EXECUTOR_SAFETY_BUFFER_BPS=5
SKEW_POLL_CYCLES=12

# Managed executor: periodic vault heartbeat (keeps Silvana-hosted executor awake)
AGENT_HEARTBEAT_MS=120000

# ────────────────────────────────────────────────────────────────────────
# Feature flags
# ────────────────────────────────────────────────────────────────────────
BITGET_ENABLED=0
HYPERLIQUID_ENABLED=0
# Reserve CEX venues — adapters built in back-end, surfaced in UI last.
# Both currently do NOT list Canton Coin (CC); activation gated on CC listing.
# See md_docs/upgrade-plan.md §6 + reference_cc_cex_listings.
BINANCE_ENABLED=0
TOOBIT_ENABLED=0
STRATEGY_MODE=paper

# ────────────────────────────────────────────────────────────────────────
# OneSwap (Canton AMM) — Sprint 3 read-client (quotes only).
# Swap execution lives in the proprietary executor, NOT open core.
# ────────────────────────────────────────────────────────────────────────
ONESWAP_ENABLED=1
# mock — deterministic synthetic quotes, no credentials (default)
# live — real devnet/mainnet quotes; requires ONESWAP_API_KEY
ONESWAP_MODE=mock
ONESWAP_ENV=devnet
# Developer key (os_live_...) from the wallet-authenticated portal.
ONESWAP_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# Temple (Canton CLOB) — Sprint 4 read-client (market data only).
# Order placement / deposit / withdraw live in the proprietary executor +
# rebalancer, NOT open core.
# ────────────────────────────────────────────────────────────────────────
TEMPLE_ENABLED=1
# mock — deterministic synthetic top-of-book, no credentials (default)
# live — real testnet/mainnet ticker; requires TEMPLE_API_KEY
TEMPLE_MODE=mock
TEMPLE_NETWORK=testnet
# API key from app.templedigitalgroup.com (KYC/KYB gated).
TEMPLE_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# Cantex (Canton AMM, by CaviarNine) — Sprint 5 read-client (quotes only).
# Swap execution (intent secp256k1) lives in the proprietary executor;
# stable-router v2 in the rebalancer. NOT open core.
# ────────────────────────────────────────────────────────────────────────
CANTEX_ENABLED=1
# mock — deterministic synthetic AMM quotes, no credentials (default)
# live — real quotes; requires CANTEX_API_KEY (via operator-key onboarding)
CANTEX_MODE=mock
CANTEX_NETWORK=mainnet
CANTEX_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# Silvana Book (Canton CLOB) — Sprint 6 read-only quote feed (CC/USDC).
# Order submission / DvP settlement / withdraw live in the proprietary
# executor/rebalancer when Silvana goes live. NOT open core.
# ────────────────────────────────────────────────────────────────────────
SILVANA_ENABLED=1
# mock — deterministic synthetic CC/USDC top-of-book (default)
# live — gRPC PricingClient via silvana-host (deferred until onboarding)
SILVANA_MODE=mock

# ────────────────────────────────────────────────────────────────────────
# Cross-cluster CC-triangulation detection (Sprint 7) — finds CC spreads
# between the USDCx cluster (OneSwap/Temple/Cantex) and the USDC cluster
# (Silvana), net of stablecoin conversion cost. Detection only; execution +
# stable-router live in the proprietary executor/rebalancer.
# ────────────────────────────────────────────────────────────────────────
CROSS_CLUSTER_ENABLED=1

# ────────────────────────────────────────────────────────────────────────
# UI auth (HMAC-signed tokens, RSA-encrypted session secrets)
# ────────────────────────────────────────────────────────────────────────
# Required for /api/auth — 32+ hex chars (generate: openssl rand -hex 32).
# If unset, the API generates an ephemeral per-process secret (all sessions
# invalidate on restart). Always set this in production.
TOKEN_SECRET=

# Bootstrap operator — used ONCE on first start when no operators exist.
# Remove these from .env after the first successful login.
OPERATOR_USERNAME=
OPERATOR_PASSWORD_BOOTSTRAP=

# MVP: login is disabled. Server bypasses all auth middleware. Set to 0 / remove
# (together with NEXT_PUBLIC_DISABLE_AUTH) to re-enable login. Never ship open
# to production.
DISABLE_AUTH=1

# ────────────────────────────────────────────────────────────────────────
# Web (apps/web) — public env vars (must start with NEXT_PUBLIC_)
# ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
# MVP: login form hidden (web uses a stub session). Set to 0 to re-enable login.
NEXT_PUBLIC_DISABLE_AUTH=1

# ────────────────────────────────────────────────────────────────────────
# AI advisory module (apps/ai-assistant) — U8, post-MVP, ADVISORY ONLY.
# Suggests; the operator confirms. No keys / DB / Telegram. See md_docs/13.
# ────────────────────────────────────────────────────────────────────────
AI_ASSISTANT_PORT=4004
AI_ASSISTANT_API_TOKEN=dev-ai-secret
AI_ASSISTANT_ENABLED=1
# heuristic (default — deterministic, no key) | anthropic | openai | ollama
AI_PROVIDER=heuristic
