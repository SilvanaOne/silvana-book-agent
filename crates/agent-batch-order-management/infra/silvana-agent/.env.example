# Параметры для onboard.sh — используются ТОЛЬКО локально, в git не попадают.
# Скопируйте в .env (этого же каталога) и заполните значения, когда инвайт придёт.

# Обязательное (для cloud-agent onboard):
SILVANA_INVITE_CODE=
SILVANA_ONBOARD_EMAIL=

# Опциональные:
SILVANA_AGENT_NAME=batch-order-management
SILVANA_RPC=https://orderbook-devnet.silvana.dev:443
