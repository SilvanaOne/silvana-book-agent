NODE_ENV=development
PORT=3000
WORKER_HEALTH_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3000

# Базовый URL apps/api для серверной части Next (`/api/backend/*`). Если пусто — `NEXT_PUBLIC_API_URL`.
BACKEND_INTERNAL_URL=http://localhost:3000

# Demo / testing tools (Manual Drift Imitator on /rebalance). Keep 0 / unset on real production-like environments.
# DEMO_TOOLS gates the API endpoint at runtime; NEXT_PUBLIC_DEMO_TOOLS bakes the UI block visibility into the web bundle.
DEMO_TOOLS=1
NEXT_PUBLIC_DEMO_TOOLS=1

# Silvana block explorer URL template — used by the Rebalance modal paperclip links.
# Must contain "{hash}" placeholder. Replace with the real Silvana scan URL when known.
NEXT_PUBLIC_SILVANA_SCAN_URL=https://silvanascan.io/tx/{hash}

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/batch_agent
REDIS_URL=redis://localhost:6379

SILVANA_RPC=https://orderbook-devnet.silvana.dev:443
SILVANA_JWT=
SILVANA_AGENT_NAME=batch-order-management
SILVANA_INVITE_CODE=
SILVANA_ONBOARD_EMAIL=
SILVANA_PRIVATE_KEY=

DEFAULT_MARKET=CC-USDC
DEFAULT_CHAIN=canton
LOG_LEVEL=info

# Этап 10 (Observability): worker пишет JSON-строки в stdout/stderr (поля см. workerExecutionJsonLog в apps/worker).
# Отдельного LOG_FORMAT не требуется — достаточно собрать контейнер/процесс лог без буфера на одну строку на событие.

RISK_MAX_ORDER_SIZE=10000
RISK_MAX_SLIPPAGE_BPS=50
RISK_MAX_DAILY_NOTIONAL=50000
REBALANCE_THRESHOLD_BPS=100

# execution-router (@batch-order/execution-router) — выбор venue по OrderIntent до адаптера (Этап 2).
ROUTER_DEFAULT_VENUE=
ROUTER_MIN_QTY_RFQ=0
ROUTER_MAX_ORDER_SIZE_OKX=50000
# Верхняя граница heuristic-маршрутизации больших qty в OKX Liquid (не ограничивает execProfile rfq|block). Пусто — без верхней границы.
ROUTER_MAX_ORDER_SIZE_LIQUID=

# Включить chooseVenue + VenueAdapter в submit-batch. По умолчанию 0 — откат: venue только из строки ордера (Этап 11 rollout).
EXECUTION_ROUTER_ENABLED=0

# Опционально: если задано, любые запросы /api/** требуют Bearer token или заголовок x-api-key с этим значением.
API_INTERNAL_KEY=

# OKX REST V5 (@batch-order/venue-adapters, Этап 5b): ключи из аккаунта OKX API (демо-ключи — в demo-trading).
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# paper | demo | … → заголовок x-simulated-trading: 1; иное / пусто → прод для реальных ключей.
OKX_TRADING_MODE=paper
# Опционально: OKX_API_BASE_URL=https://www.okx.com

# Temple / Canton HTTP (Этап 6). Для офлайна без реального Canton API: TEMPLE_STUB_ACCEPT=1
TEMPLE_API_BASE_URL=
TEMPLE_AUTH_BEARER=
TEMPLE_API_KEY=
# Имя заголовка для ключа — если ваш шлюз ожидает не стандартный X-Api-Key
TEMPLE_API_KEY_HEADER=
TEMPLE_ORDER_SUBMIT_PATH=/orders
TEMPLE_STUB_ACCEPT=

# OKX Liquidity Marketplace / RFQ (Этап 7). Stub без сети: OKX_LIQUID_STUB_ACCEPT=1 — для интеграции REST см. packages/venue-adapters/src/okx-liquid/rest.ts
OKX_LIQUID_STUB_ACCEPT=
OKX_LIQUID_API_BASE_URL=
OKX_LIQUID_API_KEY=
OKX_LIQUID_API_SECRET=
OKX_LIQUID_API_PASSPHRASE=

# Binance OTC (Этап 8) — не смешивать с retail Spot API. Офлайн: BINANCE_OTC_STUB_ACCEPT=1; «живой» каркас: BINANCE_OTC_ENABLED=1 + ключи (REST подключается отдельно после комплаенса).
BINANCE_OTC_STUB_ACCEPT=
BINANCE_OTC_ENABLED=
BINANCE_OTC_API_KEY=
BINANCE_OTC_API_SECRET=

# Параллелизм обработки BullMQ-job в worker
WORKER_CONCURRENCY=4

# Площадка исполнения по умолчанию для OrderBatch, если planned order не задаёт venue (multi-venue гибрид).
WORKER_DEFAULT_EXECUTION_VENUE=silvana

# rpc | plan_only — вызовы submitOrder/cancelOrder в book. По умолчанию: rpc при SILVANA_JWT, иначе plan_only.
WORKER_SILVANA_EXECUTION=

# Гибрид (вариант А, Шаг 3): рядом крутится cloud-agent --settlement-only, settle делает он, не воркер.
# Только лог-баннер — поведение исполнения не меняется. См. task/updated-scenario/hybrid-architecture.md.
WORKER_SILVANA_SETTLEMENT_SIDECAR=

# Гибрид (вариант Б, Шаг 4): job-тип `rfq_fill` делегирует RFQ-такер cloud-agent через CLI.
# Без этих значений `rfq_fill` ВСЕГДА завершается ошибкой `misconfigured` (это намеренно).
# Транспорт. docker — worker делает `docker exec` в sidecar (Шаг 2/3). host — бинарь на хосте.
WORKER_RFQ_TRANSPORT=
# Для docker: имя контейнера sidecar; по умолчанию bam-cloud-agent (см. infra/cloud-agent.compose.yml).
WORKER_RFQ_DOCKER_CONTAINER=
# Для host: абсолютный путь к cloud-agent (см. infra/silvana-agent/bin/cloud-agent).
WORKER_RFQ_BIN_PATH=
# Каталог с agent.toml (внутри контейнера для docker = /agent; на хосте — реальный путь).
WORKER_RFQ_AGENT_DIR=
# Безопасный дефолт: dry-run (cloud-agent готовит транзакцию, но не подписывает и не исполняет).
# 1 = dry-run; 0 = реально торгует. Каждый job может переопределить полем `dryRun` payload.
WORKER_RFQ_DRY_RUN_DEFAULT=1
# Жёсткий таймаут одного rfq_fill (мс). По умолчанию 900000 = 15 минут.
WORKER_RFQ_TIMEOUT_MS=900000

# Подписи subscribeOrders/subscribeSettlements (JWT). Отключить: 1/true.
WORKER_SILVANA_STREAM_DISABLED=

# Список market_id через запятую для фильтра стрима; одно значение = один subscribe; несколько значений или пустой список = без market_id на стримах.
WORKER_STREAM_MARKET_IDS=

# Интервал getOrderHistory (мс); 0 = выключено.
WORKER_ORDER_RECONCILE_MS=90000

# Пауза перед переподключением стримов после ошибки или EOF (мс).
WORKER_STREAM_BACKOFF_MS=8000
